<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.recymera">

    <uses-sdk />

    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature android:name="android.hardware.camera" />
    <uses-feature android:name="android.hardware.camera.autofocus" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_recymera"
        android:label="@string/tfe_ic_app_name"
        android:roundIcon="@mipmap/ic_launcher_recymera_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme.ImageClassification">

        <activity
            android:name=".ui.main.MainActivity"
            android:label="@string/tfe_ic_app_name"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.search.SearchActivity" />
        <activity android:name=".ui.detail.DetailActivity" />
        <activity android:name=".ui.camera.ClassifierActivity" />
    </application>

</manifest>
